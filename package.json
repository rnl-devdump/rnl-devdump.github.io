{
  "name": "dataset-annotation-tool",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:validation": "vite --config vite.validation.config.js",
    "dev:letter": "vite --config vite.letter.config.js",
    "build": "vite build",
    "build:dataset": "vite build",
    "build:validation": "vite build --config vite.validation.config.js",
    "build:forum": "vite build --config vite.forum.config.js",
    "build:letter": "vite build --config vite.letter.config.js && node scripts/finalize-letter-build.mjs",
    "build:all": "npm run build:dataset && npm run build:validation && npm run build:forum && npm run build:letter",
    "preview": "vite preview"
  },
  "dependencies": {
    "firebase": "^12.12.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.13",
    "@tailwindcss/vite": "^4.1.13",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "tailwindcss": "^4.1.13",
    "vite": "^7.1.7"
  }
}
